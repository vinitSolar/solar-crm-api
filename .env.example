# Application
NODE_ENV=development
PORT=5000
APP_NAME=SunSelect Solar India CRM
APP_URL=http://localhost:5000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=sunselect_crm
DB_SSL=false

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# BullMQ
QUEUE_PREFIX=sunselect

# Logger
LOG_LEVEL=info

# Mail
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@sunselect.com

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sunselect-storage
R2_PUBLIC_URL=https://pub-xxxx.r2.dev